// ═══════════════════════════════════════════════════════════════════════════════
// PERFORMANCE OPTIMIZATION
// ═══════════════════════════════════════════════════════════════════════════════

int vm_timing = 0; // Ultra-low latency mode (1000Hz polling)

// ═══════════════════════════════════════════════════════════════════════════════
// BUTTON DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

define
    // Primary Controls
    BTN_FIRE        = XB1_RT,
    BTN_ADS         = XB1_LT,
    BTN_JUMP        = XB1_A,
    BTN_CROUCH      = XB1_B,
    BTN_RELOAD      = XB1_X,
    BTN_SWAP        = XB1_Y,
    BTN_SPRINT      = XB1_LS,
    BTN_MELEE       = XB1_RS,
    BTN_LB          = XB1_LB,
    BTN_RB          = XB1_RB,

    // Menu Controls
    BTN_MENU        = XB1_MENU,
    BTN_VIEW        = XB1_VIEW,
    BTN_UP          = XB1_UP,
    BTN_DOWN        = XB1_DOWN,
    BTN_LEFT        = XB1_LEFT,
    BTN_RIGHT       = XB1_RIGHT,

    // Analog Sticks
    STICK_LX        = XB1_LX,
    STICK_LY        = XB1_LY,
    STICK_RX        = XB1_RX,
    STICK_RY        = XB1_RY,

    // Feature Indices
    FEAT_MOVEMENT_RESET     = 0,
    FEAT_ANTI_RECOIL        = 1,
    FEAT_SNAKING            = 2,
    FEAT_WALL_BOUNCE        = 3,
    FEAT_DROP_SHOT          = 4,
    FEAT_BUNNY_HOP          = 5,
    FEAT_WEAPON_SWAP        = 6,
    FEAT_AUTO_SPRINT        = 7,
    FEAT_TACTICAL_SPRINT    = 8,

    // Activation Modes
    MODE_HOLD           = 0,
    MODE_TOGGLE         = 1,
    MODE_LONG_PRESS     = 2,
    MODE_CONDITIONAL    = 3,

    // Key Mappings
    KEY_NONE    = 0,
    KEY_RT      = 1,
    KEY_LT      = 2,
    KEY_RB      = 3,
    KEY_LB      = 4,
    KEY_A       = 5,
    KEY_B       = 6,
    KEY_X       = 7,
    KEY_Y       = 8,
    KEY_LS      = 9,
    KEY_RS      = 10,
    KEY_UP      = 11,
    KEY_DOWN    = 12,
    KEY_LEFT    = 13,
    KEY_RIGHT   = 14,

    // Timing Constants
    TIMING_MIN      = 1,
    TIMING_MAX      = 500,
    LONG_PRESS_TIME = 500,
    TIMER_RESET_VAL = 30000, // Reset timers every 30 seconds to prevent overflow

    // Profile System
    PROFILE_COUNT   = 3,
    PROFILE_1       = 0,
    PROFILE_2       = 1,
    PROFILE_3       = 2;

// ═══════════════════════════════════════════════════════════════════════════════
// CONFIGURATION ARRAYS
// ═══════════════════════════════════════════════════════════════════════════════

// Feature Enable/Disable (9 features)
int feature_enabled[9] = {
    FALSE,  // [0] Movement Reset
    TRUE,   // [1] Anti-Recoil (default ON)
    FALSE,  // [2] Snaking
    FALSE,  // [3] Wall Bounce
    FALSE,  // [4] Drop Shot
    FALSE,  // [5] Bunny Hop
    FALSE,  // [6] Weapon Swap
    FALSE,  // [7] Auto Sprint
    FALSE   // [8] Tactical Sprint
};

int feature_active[9];

int activation_mode[9] = {
    MODE_HOLD,          MODE_CONDITIONAL,   MODE_HOLD,
    MODE_HOLD,          MODE_CONDITIONAL,   MODE_HOLD,
    MODE_TOGGLE,        MODE_TOGGLE,        MODE_TOGGLE
};

int key_primary[9] = {
    KEY_B,      KEY_RT,     KEY_DOWN,   KEY_A,      KEY_RT,
    KEY_A,      KEY_Y,      KEY_LS,     KEY_LS
};

int key_secondary[9] = {
    KEY_NONE,   KEY_LT,     KEY_NONE,   KEY_NONE,   KEY_LT,
    KEY_NONE,   KEY_NONE,   KEY_NONE,   KEY_NONE
};

int timing_delay[9] = {
    280,    10,     120,    300,    50,
    150,    100,    200,    150
};

// Anti-Recoil Configuration
int recoil_vertical = 35;
int recoil_horizontal = 0;
int recoil_adaptive = 75;

// Other Configuration
int slide_cancel_mode = 1;
int snake_speed = 8;
int snake_range = 25;
int wall_bounce_strength = 30;
int dropshot_restand = TRUE;
int weapon_swap_count = 2;
int tac_sprint_auto = TRUE;
int tac_sprint_cancel_protect = TRUE;

// ═══════════════════════════════════════════════════════════════════════════════
// PROFILE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

int current_profile = PROFILE_1;
int profile_saved[3];

// Profile storage (flattened for GPC compatibility)
int profile_feat_p1[9];
int profile_feat_p2[9];
int profile_feat_p3[9];
int profile_recoil_v[3];
int profile_recoil_h[3];
int profile_slide_mode[3];

// ═══════════════════════════════════════════════════════════════════════════════
// RUNTIME VARIABLES
// ═══════════════════════════════════════════════════════════════════════════════

// Input States
int is_firing, is_aiming, is_moving_forward, is_jumping, is_crouching;

// Feature Timers (with overflow protection)
int timer_movement_reset;
int timer_snaking;
int timer_wall_bounce;
int timer_bunny_hop;
int timer_auto_sprint;
int timer_tactical_sprint;
int global_timer; // For overflow reset

// Key Press Tracking
int key_press_timer[9];
int key_press_state[9];

// Anti-Recoil State
int ar_rumble_last;
int ar_adaptive_mult = 100;
int ar_burst_timer;

// Feature-Specific State
int snake_direction = 1;
int snake_timer;
int wb_active;
int wb_timer;
int drop_active;
int drop_restand_pending;
int weapon_swap_active;
int tac_sprint_active;
int tac_sprint_last_press;
int tac_sprint_press_count;

// Quick Toggle State
int quick_toggle_index;

// Menu System
int menu_active = FALSE;
int menu_category = 0;
int menu_item = 0;
int menu_needs_save = FALSE;

// LED & Feedback
int led_state = 0;
int led_timer;
int led_profile_color[3] = {2, 3, 4}; // Green, Blue, Purple

// Conflict Detection
int conflict_warning_timer;
int conflict_detected;
int conflict_blink_state;

// Rumble Feedback State (non-blocking)
int rumble_active;
int rumble_timer;
int rumble_pattern; // 0=off, 1=single, 2=double, 3=triple

// ═══════════════════════════════════════════════════════════════════════════════
// INITIALIZATION
// ═══════════════════════════════════════════════════════════════════════════════

init {
    vm_tctrl(vm_timing);

    load_settings();
    load_profile(current_profile);

    // Initialize timers
    timer_movement_reset = 0;
    timer_snaking = 0;
    timer_wall_bounce = 0;
    timer_bunny_hop = 0;
    timer_auto_sprint = 0;
    timer_tactical_sprint = 0;
    global_timer = 0;
    ar_burst_timer = 0;

    // Initialize arrays
    int i;
    for(i = 0; i < 9; i++) {
        key_press_timer[i] = 0;
        key_press_state[i] = FALSE;
        feature_active[i] = FALSE;
    }

    // Initialize profile arrays
    for(i = 0; i < 3; i++) {
        profile_saved[i] = FALSE;
        profile_recoil_v[i] = 35;
        profile_recoil_h[i] = 0;
        profile_slide_mode[i] = 1;
    }

    for(i = 0; i < 9; i++) {
        profile_feat_p1[i] = FALSE;
        profile_feat_p2[i] = FALSE;
        profile_feat_p3[i] = FALSE;
    }

    // Initialize other states
    tac_sprint_active = FALSE;
    tac_sprint_last_press = 0;
    tac_sprint_press_count = 0;
    quick_toggle_index = 0;
    conflict_warning_timer = 0;
    conflict_detected = FALSE;
    rumble_active = FALSE;
    rumble_timer = 0;
    rumble_pattern = 0;
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN LOOP
// ═══════════════════════════════════════════════════════════════════════════════

main {

    // Update global timer with overflow protection
    global_timer += get_rtime();
    if(global_timer > TIMER_RESET_VAL) {
        reset_timers();
    }

    // Handle non-blocking rumble feedback
    handle_rumble_feedback();

    update_input_states();

    // Menu activation: Hold LT + Press OPTIONS
    if(get_val(BTN_ADS) > 90 && event_press(BTN_MENU) && !menu_active) {
        menu_active = TRUE;
        menu_category = 0;
        menu_item = 0;
    }

    if(menu_active) {
        handle_menu();
        update_led_status();
        return;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // PROFILE SYSTEM CONTROLS (Non-blocking)
    // ═══════════════════════════════════════════════════════════════════════════

    // Save Current Profile: Hold LT + Press X
    if(get_val(BTN_ADS) > 90 && event_press(BTN_RELOAD)) {
        save_profile(current_profile);
        trigger_rumble(1); // Single pulse
    }

    // Switch Profile: Hold LB + Press LS
    if(get_val(BTN_LB) > 50 && event_press(BTN_SPRINT)) {
        current_profile++;
        if(current_profile >= PROFILE_COUNT) current_profile = 0;
        load_profile(current_profile);
        trigger_rumble(2); // Double pulse
    }

    // Reset to Defaults: Hold LT + LB + RB + Press VIEW
    if(get_val(BTN_ADS) > 90 && get_val(BTN_LB) > 50 && get_val(BTN_RB) > 50 && event_press(BTN_VIEW)) {
        reset_to_defaults();
        trigger_rumble(3); // Triple pulse
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // ENHANCED QUICK TOGGLES (Non-blocking)
    // ═══════════════════════════════════════════════════════════════════════════

    handle_quick_toggles();

    // ═══════════════════════════════════════════════════════════════════════════
    // CONFLICT PREVENTION
    // ═══════════════════════════════════════════════════════════════════════════

    check_feature_conflicts();

    // Show conflict warning via LED (non-blocking)
    if(conflict_detected) {
        conflict_warning_timer += get_rtime();
        if(conflict_warning_timer < 2000) {
            // Blink red
            if((conflict_warning_timer / 250) % 2 == 0) {
                led(LED_4, 1); // Red
            } else {
                led(LED_4, 0); // Off
            }
        } else {
            conflict_detected = FALSE;
            conflict_warning_timer = 0;
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // FEATURE ACTIVATION
    // ═══════════════════════════════════════════════════════════════════════════

    update_feature_states();

    // [1] MOVEMENT RESET (Slide Cancel)
    if(feature_enabled[FEAT_MOVEMENT_RESET] && feature_active[FEAT_MOVEMENT_RESET]) {
        if(event_press(BTN_CROUCH) && is_moving_forward && !tac_sprint_active) {
            if(slide_cancel_mode == 0) combo_run(combo_slide_cancel_legacy);
            else if(slide_cancel_mode == 1) combo_run(combo_slide_cancel_bo7);
            else combo_run(combo_slide_cancel_jump);
        }
    }

    // [2] ANTI-RECOIL
    if(feature_enabled[FEAT_ANTI_RECOIL] && feature_active[FEAT_ANTI_RECOIL]) {
        apply_anti_recoil();
    } else {
        ar_burst_timer = 0;
        ar_adaptive_mult = 100;
    }

    // [3] SNAKING
    if(feature_enabled[FEAT_SNAKING] && feature_active[FEAT_SNAKING]) {
        apply_snaking();
    } else {
        snake_timer = 0;
    }

    // [4] WALL BOUNCE
    if(feature_enabled[FEAT_WALL_BOUNCE] && feature_active[FEAT_WALL_BOUNCE]) {
        apply_wall_bounce();
    } else {
        wb_timer = 0;
        wb_active = FALSE;
    }

    // [5] DROP SHOT
    if(feature_enabled[FEAT_DROP_SHOT] && feature_active[FEAT_DROP_SHOT]) {
        if(is_firing && !drop_active) {
            combo_run(combo_drop_shot);
            drop_active = TRUE;
        }
    } else {
        drop_active = FALSE;
    }

    // Auto re-stand
    if(drop_restand_pending && dropshot_restand) {
        if(!is_firing && get_ptime(BTN_FIRE) > 1000) {
            combo_run(combo_restand);
            drop_restand_pending = FALSE;
        }
    }

    // [6] BUNNY HOP
    if(feature_enabled[FEAT_BUNNY_HOP] && feature_active[FEAT_BUNNY_HOP]) {
        if(is_jumping && !combo_running(combo_bunny_hop)) {
            timer_bunny_hop += get_rtime();
            if(timer_bunny_hop >= timing_delay[FEAT_BUNNY_HOP]) {
                combo_run(combo_bunny_hop);
                timer_bunny_hop = 0;
            }
        } else if(!is_jumping) {
            timer_bunny_hop = 0;
        }
    }

    // [7] WEAPON SWAP
    if(feature_enabled[FEAT_WEAPON_SWAP] && feature_active[FEAT_WEAPON_SWAP]) {
        if(event_press(BTN_SWAP) && !weapon_swap_active) {
            weapon_swap_active = TRUE;
            combo_run(combo_weapon_swap);
        }
    }

    // [8] AUTO SPRINT
    if(feature_enabled[FEAT_AUTO_SPRINT] && feature_active[FEAT_AUTO_SPRINT]) {
        if(is_moving_forward && !is_firing && !tac_sprint_active) {
            timer_auto_sprint += get_rtime();
            if(timer_auto_sprint >= timing_delay[FEAT_AUTO_SPRINT]) {
                set_val(BTN_SPRINT, 100);
            }
        } else {
            timer_auto_sprint = 0;
        }
    }

    // [9] TACTICAL SPRINT
    if(feature_enabled[FEAT_TACTICAL_SPRINT] && feature_active[FEAT_TACTICAL_SPRINT]) {
        apply_tactical_sprint();
    }

    // Update LED (if not showing conflict)
    if(!conflict_detected) {
        update_led_status();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// NON-BLOCKING RUMBLE FEEDBACK SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

function trigger_rumble(int pattern) {
    rumble_pattern = pattern;
    rumble_active = TRUE;
    rumble_timer = 0;
}

function handle_rumble_feedback() {
    if(!rumble_active) return;

    rumble_timer += get_rtime();

    if(rumble_pattern == 1) {
        // Single pulse (100ms)
        if(rumble_timer < 100) {
            set_rumble(RUMBLE_A, 30);
        } else {
            set_rumble(RUMBLE_A, 0);
            rumble_active = FALSE;
        }
    } else if(rumble_pattern == 2) {
        // Double pulse (60ms on, 40ms off, 60ms on)
        if(rumble_timer < 60) {
            set_rumble(RUMBLE_A, 50);
        } else if(rumble_timer < 100) {
            set_rumble(RUMBLE_A, 0);
        } else if(rumble_timer < 160) {
            set_rumble(RUMBLE_A, 50);
        } else {
            set_rumble(RUMBLE_A, 0);
            rumble_active = FALSE;
        }
    } else if(rumble_pattern == 3) {
        // Triple pulse
        if(rumble_timer < 80 || (rumble_timer >= 120 && rumble_timer < 200) || (rumble_timer >= 240 && rumble_timer < 320)) {
            set_rumble(RUMBLE_A, 40);
        } else if(rumble_timer >= 320) {
            set_rumble(RUMBLE_A, 0);
            rumble_active = FALSE;
        } else {
            set_rumble(RUMBLE_A, 0);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TIMER OVERFLOW PROTECTION
// ═══════════════════════════════════════════════════════════════════════════════

function reset_timers() {
    global_timer = 0;
    timer_movement_reset = 0;
    timer_snaking = 0;
    timer_wall_bounce = 0;
    timer_bunny_hop = 0;
    timer_auto_sprint = 0;
    ar_burst_timer = 0;
}

// ═══════════════════════════════════════════════════════════════════════════════
// INPUT STATE UPDATE
// ═══════════════════════════════════════════════════════════════════════════════

function update_input_states() {
    is_firing = get_val(BTN_FIRE) > 50;
    is_aiming = get_val(BTN_ADS) > 50;
    is_moving_forward = get_val(STICK_LY) < -30;
    is_jumping = get_val(BTN_JUMP) > 50;
    is_crouching = get_val(BTN_CROUCH) > 50;
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENHANCED QUICK TOGGLES (Non-blocking)
// ═══════════════════════════════════════════════════════════════════════════════

function handle_quick_toggles() {

    // LB + RB = Cycle features
    if(get_val(BTN_LB) > 50 && event_press(BTN_RB)) {
        quick_toggle_index++;
        if(quick_toggle_index >= 9) quick_toggle_index = 0;
        feature_enabled[quick_toggle_index] = !feature_enabled[quick_toggle_index];
        trigger_rumble(feature_enabled[quick_toggle_index] ? 2 : 1);
    }

    // Individual toggles
    if(get_val(BTN_LB) > 50) {
        if(event_press(BTN_UP)) {
            feature_enabled[FEAT_ANTI_RECOIL] = !feature_enabled[FEAT_ANTI_RECOIL];
            trigger_rumble(feature_enabled[FEAT_ANTI_RECOIL] ? 2 : 1);
        }
        if(event_press(BTN_DOWN)) {
            feature_enabled[FEAT_SNAKING] = !feature_enabled[FEAT_SNAKING];
            trigger_rumble(feature_enabled[FEAT_SNAKING] ? 2 : 1);
        }
        if(event_press(BTN_LEFT)) {
            feature_enabled[FEAT_DROP_SHOT] = !feature_enabled[FEAT_DROP_SHOT];
            trigger_rumble(feature_enabled[FEAT_DROP_SHOT] ? 2 : 1);
        }
        if(event_press(BTN_RIGHT)) {
            feature_enabled[FEAT_BUNNY_HOP] = !feature_enabled[FEAT_BUNNY_HOP];
            trigger_rumble(feature_enabled[FEAT_BUNNY_HOP] ? 2 : 1);
        }
        if(event_press(BTN_VIEW)) {
            feature_enabled[FEAT_WALL_BOUNCE] = !feature_enabled[FEAT_WALL_BOUNCE];
            trigger_rumble(feature_enabled[FEAT_WALL_BOUNCE] ? 2 : 1);
            set_val(BTN_VIEW, 0);
        }
        if(event_press(BTN_MENU)) {
            feature_enabled[FEAT_AUTO_SPRINT] = !feature_enabled[FEAT_AUTO_SPRINT];
            trigger_rumble(feature_enabled[FEAT_AUTO_SPRINT] ? 2 : 1);
            set_val(BTN_MENU, 0);
        }
        if(event_press(BTN_MELEE)) {
            feature_enabled[FEAT_TACTICAL_SPRINT] = !feature_enabled[FEAT_TACTICAL_SPRINT];
            trigger_rumble(feature_enabled[FEAT_TACTICAL_SPRINT] ? 2 : 1);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONFLICT PREVENTION (Fixed logic)
// ═══════════════════════════════════════════════════════════════════════════════

function check_feature_conflicts() {
    int conflict_found = FALSE;

    // Snaking conflicts with Drop Shot and Bunny Hop
    if(feature_enabled[FEAT_SNAKING] && feature_active[FEAT_SNAKING]) {
        if(feature_active[FEAT_DROP_SHOT]) {
            feature_active[FEAT_DROP_SHOT] = FALSE;
            conflict_found = TRUE;
        }
        if(feature_active[FEAT_BUNNY_HOP]) {
            feature_active[FEAT_BUNNY_HOP] = FALSE;
            conflict_found = TRUE;
        }
    }

    // Drop Shot conflicts with Snaking and Bunny Hop
    if(feature_enabled[FEAT_DROP_SHOT] && feature_active[FEAT_DROP_SHOT]) {
        if(feature_active[FEAT_SNAKING]) {
            feature_active[FEAT_SNAKING] = FALSE;
            conflict_found = TRUE;
        }
        if(feature_active[FEAT_BUNNY_HOP]) {
            feature_active[FEAT_BUNNY_HOP] = FALSE;
            conflict_found = TRUE;
        }
    }

    // Bunny Hop conflicts with Snaking and Drop Shot
    if(feature_enabled[FEAT_BUNNY_HOP] && feature_active[FEAT_BUNNY_HOP]) {
        if(feature_active[FEAT_SNAKING]) {
            feature_active[FEAT_SNAKING] = FALSE;
            conflict_found = TRUE;
        }
        if(feature_active[FEAT_DROP_SHOT]) {
            feature_active[FEAT_DROP_SHOT] = FALSE;
            conflict_found = TRUE;
        }
    }

    if(conflict_found && !conflict_detected) {
        conflict_detected = TRUE;
        conflict_warning_timer = 0;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TACTICAL SPRINT
// ═══════════════════════════════════════════════════════════════════════════════

function apply_tactical_sprint() {
    if(!is_moving_forward) {
        tac_sprint_press_count = 0;
        tac_sprint_last_press = 0;
        tac_sprint_active = FALSE;
        return;
    }

    // Detect double-tap sprint
    if(event_press(BTN_SPRINT)) {
        timer_tactical_sprint = 0;

        if(tac_sprint_press_count > 0) {
            tac_sprint_active = TRUE;
            combo_run(combo_tactical_sprint);
            tac_sprint_press_count = 0;
        } else {
            tac_sprint_press_count = 1;
        }
    }

    // Reset double-tap if too slow
    if(tac_sprint_press_count > 0) {
        timer_tactical_sprint += get_rtime();
        if(timer_tactical_sprint > timing_delay[FEAT_TACTICAL_SPRINT]) {
            tac_sprint_press_count = 0;
        }
    }

    // Maintain tactical sprint
    if(tac_sprint_active) {
        // Cancel protection
        if(tac_sprint_cancel_protect && get_val(BTN_ADS) > 10 && get_val(BTN_ADS) < 90) {
            set_val(BTN_ADS, 0);
        }

        // Deactivate if stopped or firing
        if(!is_moving_forward || is_firing) {
            tac_sprint_active = FALSE;
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FEATURE STATE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

function update_feature_states() {
    int i;
    for(i = 0; i < 9; i++) {
        if(!feature_enabled[i]) {
            feature_active[i] = FALSE;
            continue;
        }

        int primary_pressed = is_key_pressed(key_primary[i]);
        int secondary_pressed = is_key_pressed(key_secondary[i]);

        if(activation_mode[i] == MODE_HOLD) {
            feature_active[i] = primary_pressed;
        } else if(activation_mode[i] == MODE_TOGGLE) {
            if(primary_pressed && !key_press_state[i]) {
                feature_active[i] = !feature_active[i];
                key_press_state[i] = TRUE;
            } else if(!primary_pressed) {
                key_press_state[i] = FALSE;
            }
        } else if(activation_mode[i] == MODE_LONG_PRESS) {
            if(primary_pressed) {
                key_press_timer[i] += get_rtime();
                if(key_press_timer[i] >= LONG_PRESS_TIME && !key_press_state[i]) {
                    feature_active[i] = !feature_active[i];
                    key_press_state[i] = TRUE;
                }
            } else {
                key_press_timer[i] = 0;
                key_press_state[i] = FALSE;
            }
        } else if(activation_mode[i] == MODE_CONDITIONAL) {
            if(key_secondary[i] == KEY_NONE) {
                feature_active[i] = primary_pressed;
            } else {
                feature_active[i] = primary_pressed && secondary_pressed;
            }
        }
    }
}

function is_key_pressed(int key_code) {
    if(key_code == KEY_NONE) return FALSE;
    if(key_code == KEY_RT) return get_val(BTN_FIRE) > 50;
    if(key_code == KEY_LT) return get_val(BTN_ADS) > 50;
    if(key_code == KEY_RB) return get_val(BTN_RB) > 50;
    if(key_code == KEY_LB) return get_val(BTN_LB) > 50;
    if(key_code == KEY_A) return get_val(BTN_JUMP) > 50;
    if(key_code == KEY_B) return get_val(BTN_CROUCH) > 50;
    if(key_code == KEY_X) return get_val(BTN_RELOAD) > 50;
    if(key_code == KEY_Y) return get_val(BTN_SWAP) > 50;
    if(key_code == KEY_LS) return get_val(BTN_SPRINT) > 50;
    if(key_code == KEY_RS) return get_val(BTN_MELEE) > 50;
    if(key_code == KEY_UP) return get_val(BTN_UP) > 50;
    if(key_code == KEY_DOWN) return get_val(BTN_DOWN) > 50;
    if(key_code == KEY_LEFT) return get_val(BTN_LEFT) > 50;
    if(key_code == KEY_RIGHT) return get_val(BTN_RIGHT) > 50;
    return FALSE;
}

// ═══════════════════════════════════════════════════════════════════════════════
// ANTI-RECOIL
// ═══════════════════════════════════════════════════════════════════════════════

function apply_anti_recoil() {
    if(!is_aiming || !is_firing) {
        ar_burst_timer = 0;
        return;
    }

    int rumble = get_rumble(RUMBLE_B);
    if(rumble < get_rumble(RUMBLE_A) && get_rumble(RUMBLE_A) < 100) {
        rumble = get_rumble(RUMBLE_A);
    }

    // Adaptive weapon detection
    if(rumble > 20 && rumble < 90) {
        if(rumble > 60) {
            ar_adaptive_mult = 100 + ((rumble - 60) * recoil_adaptive / 30);
        } else if(rumble > 40) {
            ar_adaptive_mult = 90 + ((rumble - 40) * recoil_adaptive / 50);
        } else {
            ar_adaptive_mult = 80 + ((rumble - 20) * recoil_adaptive / 100);
        }
    } else {
        ar_adaptive_mult = 100;
    }

    int vert_strength = (recoil_vertical * ar_adaptive_mult) / 100;
    int hori_strength = (recoil_horizontal * ar_adaptive_mult) / 100;

    // Burst boost
    if(rumble > 15 && rumble < 95) {
        ar_burst_timer += get_rtime();
        if(ar_burst_timer < 200) {
            vert_strength = vert_strength * 2 + (rumble / 2);
        } else if(ar_burst_timer < 1000) {
            vert_strength = vert_strength + (rumble / 3);
        } else {
            vert_strength = vert_strength + (rumble / 4);
        }
    } else {
        ar_burst_timer = 0;
    }

    // Apply compensation
    if(hori_strength != 0) {
        set_val(STICK_RX, clamp(get_val(STICK_RX) + hori_strength, -100, 100));
    }
    set_val(STICK_RY, clamp(get_val(STICK_RY) + vert_strength, -100, 100));
}

// ═══════════════════════════════════════════════════════════════════════════════
// SNAKING
// ═══════════════════════════════════════════════════════════════════════════════

function apply_snaking() {
    if(!is_crouching && get_val(BTN_DOWN) < 10) {
        snake_timer = 0;
        return;
    }

    snake_timer += get_rtime();
    if(snake_timer >= (100 / snake_speed)) {
        snake_direction *= -1;
        snake_timer = 0;
    }

    int snake_offset = snake_direction * snake_range * 655;
    set_val(STICK_LX, clamp(get_val(STICK_LX) + snake_offset, -10000, 10000));
}

// ═══════════════════════════════════════════════════════════════════════════════
// WALL BOUNCE
// ═══════════════════════════════════════════════════════════════════════════════

function apply_wall_bounce() {
    int near_wall = abs(get_val(STICK_LX)) > 20 || abs(get_val(STICK_LY)) > 20;
    int looking_angle = abs(get_val(STICK_RX)) > 15;

    if(is_jumping && near_wall && looking_angle) {
        wb_timer += get_rtime();
        wb_active = TRUE;

        if(wb_timer > 50 && wb_timer < 250) {
            int assist_strength = wall_bounce_strength / 10;
            if(get_val(STICK_RY) > -15) {
                set_val(STICK_RY, get_val(STICK_RY) - assist_strength);
            }
            if(abs(get_val(STICK_RX)) < 40) {
                int direction = (get_val(STICK_RX) > 0) ? 1 : -1;
                set_val(STICK_RX, get_val(STICK_RX) + (assist_strength * direction));
            }
        }

        if(wb_timer > timing_delay[FEAT_WALL_BOUNCE] - 20 && wb_timer < timing_delay[FEAT_WALL_BOUNCE] + 20) {
            if(!combo_running(combo_wall_bounce)) {
                combo_run(combo_wall_bounce);
            }
        }
    } else {
        wb_timer = 0;
        wb_active = FALSE;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROFILE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

function save_profile(int profile_idx) {
    if(profile_idx < 0 || profile_idx >= PROFILE_COUNT) return;

    int i;
    if(profile_idx == 0) {
        for(i = 0; i < 9; i++) profile_feat_p1[i] = feature_enabled[i];
    } else if(profile_idx == 1) {
        for(i = 0; i < 9; i++) profile_feat_p2[i] = feature_enabled[i];
    } else {
        for(i = 0; i < 9; i++) profile_feat_p3[i] = feature_enabled[i];
    }

    profile_recoil_v[profile_idx] = recoil_vertical;
    profile_recoil_h[profile_idx] = recoil_horizontal;
    profile_slide_mode[profile_idx] = slide_cancel_mode;
    profile_saved[profile_idx] = TRUE;

    save_settings();
}

function load_profile(int profile_idx) {
    if(profile_idx < 0 || profile_idx >= PROFILE_COUNT) return;
    if(!profile_saved[profile_idx]) return;

    int i;
    if(profile_idx == 0) {
        for(i = 0; i < 9; i++) feature_enabled[i] = profile_feat_p1[i];
    } else if(profile_idx == 1) {
        for(i = 0; i < 9; i++) feature_enabled[i] = profile_feat_p2[i];
    } else {
        for(i = 0; i < 9; i++) feature_enabled[i] = profile_feat_p3[i];
    }

    recoil_vertical = profile_recoil_v[profile_idx];
    recoil_horizontal = profile_recoil_h[profile_idx];
    slide_cancel_mode = profile_slide_mode[profile_idx];
}

// ═══════════════════════════════════════════════════════════════════════════════
// MENU SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

function handle_menu() {
    if(event_press(BTN_MENU) || event_press(BTN_CROUCH)) {
        menu_active = FALSE;
        if(menu_needs_save) {
            save_settings();
            menu_needs_save = FALSE;
        }
        return;
    }

    if(event_press(BTN_LEFT)) {
        menu_category--;
        if(menu_category < 0) menu_category = 5;
        menu_item = 0;
    }
    if(event_press(BTN_RIGHT)) {
        menu_category++;
        if(menu_category > 5) menu_category = 0;
        menu_item = 0;
    }

    if(event_press(BTN_UP)) {
        menu_item--;
        if(menu_item < 0) menu_item = 8;
    }
    if(event_press(BTN_DOWN)) {
        menu_item++;
        if(menu_item > 8) menu_item = 0;
    }

    if(menu_category == 0) {
        if(event_press(BTN_JUMP)) {
            feature_enabled[menu_item] = !feature_enabled[menu_item];
            menu_needs_save = TRUE;
        }
    }

    block_all_inputs();
}

function block_all_inputs() {
    set_val(BTN_FIRE, 0);
    set_val(BTN_ADS, 0);
    set_val(BTN_JUMP, 0);
    set_val(BTN_RELOAD, 0);
    set_val(BTN_SWAP, 0);
    set_val(BTN_SPRINT, 0);
    set_val(BTN_MELEE, 0);
}

// ═══════════════════════════════════════════════════════════════════════════════
// PERSISTENT STORAGE
// ═══════════════════════════════════════════════════════════════════════════════

function save_settings() {
    int packed = 0;
    int i;
    for(i = 0; i < 9; i++) {
        if(feature_enabled[i]) packed |= (1 << i);
    }
    set_pvar(SPVAR_1, packed);
    set_pvar(SPVAR_2, current_profile);
    set_pvar(SPVAR_3, recoil_vertical);
    set_pvar(SPVAR_4, recoil_horizontal);
}

function load_settings() {
    int packed = get_pvar(SPVAR_1, 0, 0, 511);
    int i;
    for(i = 0; i < 9; i++) {
        feature_enabled[i] = (packed & (1 << i)) != 0;
    }
    current_profile = get_pvar(SPVAR_2, 0, 0, 2);
    recoil_vertical = get_pvar(SPVAR_3, 0, 0, 100);
    if(recoil_vertical == 0) recoil_vertical = 35;
    recoil_horizontal = get_pvar(SPVAR_4, 0, -50, 50);
}

function reset_to_defaults() {
    int i;
    for(i = 0; i < 9; i++) feature_enabled[i] = FALSE;
    feature_enabled[FEAT_ANTI_RECOIL] = TRUE;
    recoil_vertical = 35;
    recoil_horizontal = 0;
    slide_cancel_mode = 1;
    save_settings();
}

// ═══════════════════════════════════════════════════════════════════════════════
// LED STATUS
// ═══════════════════════════════════════════════════════════════════════════════

function update_led_status() {
    led_timer += get_rtime();

    if(menu_active) {
        if(led_timer >= 500) {
            led_state = !led_state;
            led(LED_4, led_state ? 1 : 0);
            led_timer = 0;
        }
    } else {
        int active_count = 0;
        int i;
        for(i = 0; i < 9; i++) {
            if(feature_enabled[i] && feature_active[i]) active_count++;
        }

        if(active_count > 0) {
            led(LED_4, led_profile_color[current_profile]);
        } else if(feature_enabled[FEAT_ANTI_RECOIL]) {
            if(led_timer >= 1000) {
                led_state = !led_state;
                led(LED_4, led_state ? led_profile_color[current_profile] : 0);
                led_timer = 0;
            }
        } else {
            led(LED_4, 0);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMBO SEQUENCES
// ═══════════════════════════════════════════════════════════════════════════════

combo combo_slide_cancel_legacy {
    set_val(BTN_CROUCH, 100);
    wait(1);
    set_val(BTN_CROUCH, 0);
    wait(timing_delay[FEAT_MOVEMENT_RESET]);
    set_val(BTN_CROUCH, 100);
    wait(1);
    set_val(BTN_JUMP, 100);
    wait(1);
}

combo combo_slide_cancel_bo7 {
    set_val(BTN_CROUCH, 100);
    wait(1);
    wait(timing_delay[FEAT_MOVEMENT_RESET]);
    set_val(BTN_ADS, 100);
    wait(1);
    set_val(BTN_ADS, 0);
    wait(1);
    set_val(BTN_JUMP, 100);
    wait(1);
}

combo combo_slide_cancel_jump {
    set_val(BTN_CROUCH, 100);
    wait(1);
    set_val(BTN_CROUCH, 0);
    wait(timing_delay[FEAT_MOVEMENT_RESET]);
    set_val(BTN_JUMP, 100);
    wait(1);
}

combo combo_drop_shot {
    set_val(BTN_CROUCH, 100);
    wait(timing_delay[FEAT_DROP_SHOT]);
    set_val(BTN_CROUCH, 0);
    drop_restand_pending = TRUE;
}

combo combo_restand {
    set_val(BTN_CROUCH, 100);
    wait(50);
    set_val(BTN_CROUCH, 0);
}

combo combo_bunny_hop {
    set_val(BTN_JUMP, 100);
    wait(1);
    set_val(BTN_JUMP, 0);
    wait(1);
}

combo combo_wall_bounce {
    set_val(BTN_JUMP, 100);
    wait(1);
    wait(1);
}

combo combo_weapon_swap {
    set_val(BTN_SWAP, 100);
    wait(1);
    set_val(BTN_SWAP, 0);
    wait(timing_delay[FEAT_WEAPON_SWAP]);
    set_val(BTN_SWAP, 100);
    wait(1);
    weapon_swap_active = FALSE;
}

combo combo_tactical_sprint {
    set_val(BTN_SPRINT, 100);
    wait(50);
    set_val(BTN_SPRINT, 0);
    wait(50);
    set_val(BTN_SPRINT, 100);
    wait(100);
}

// ═══════════════════════════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

function clamp(int value, int min_val, int max_val) {
    if(value < min_val) return min_val;
    if(value > max_val) return max_val;
    return value;
}

function abs(int value) {
    return (value < 0) ? -value : value;
}

